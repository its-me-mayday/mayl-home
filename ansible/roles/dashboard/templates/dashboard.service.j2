[Unit]
Description=mayl-home Email Dashboard
After=network.target ollama.service

[Service]
User=archiver
WorkingDirectory=/home/archiver/app
ExecStart=/home/archiver/venv/bin/python main.py
Restart=always
RestartSec=10
Environment=PYTHONUNBUFFERED=1
Environment=IMAP_HOST={{ imap_host }}
Environment=IMAP_USER={{ imap_user }}
Environment=IMAP_PASSWORD={{ imap_password }}

[Install]
WantedBy=multi-user.target
